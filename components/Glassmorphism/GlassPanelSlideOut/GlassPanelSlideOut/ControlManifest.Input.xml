<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="MegaPCF" constructor="GlassPanelSlideOut" version="1.0.0" display-name-key="GlassPanelSlideOut" description-key="Slide-out glassmorphism panel with fluid animations and dynamic content zones" control-type="standard">
    <external-service-usage enabled="false" />

    <property name="isOpen" display-name-key="Is Open" description-key="Bind to a Two Options field to control panel open/close state." of-type="TwoOptions" usage="bound" required="true" />

    <property name="panelTitle" display-name-key="Panel Title" description-key="Title displayed at the top of the slide-out panel." of-type="SingleLine.Text" usage="input" required="false" />

    <property name="slideDirection" display-name-key="Slide Direction" description-key="Direction the panel slides from." of-type="Enum" usage="input" required="false">
      <value name="left" display-name-key="Left">left</value>
      <value name="right" display-name-key="Right" default="true">right</value>
      <value name="top" display-name-key="Top">top</value>
      <value name="bottom" display-name-key="Bottom">bottom</value>
    </property>

    <property name="blurIntensity" display-name-key="Blur Intensity" description-key="Backdrop blur in pixels (default: 20)." of-type="Whole.None" usage="input" required="false" />

    <property name="tintColor" display-name-key="Tint Color" description-key="Background tint color in rgba format." of-type="SingleLine.Text" usage="input" required="false" />

    <property name="panelSize" display-name-key="Panel Size" description-key="Panel size preset." of-type="Enum" usage="input" required="false">
      <value name="small" display-name-key="Small (320px)">small</value>
      <value name="medium" display-name-key="Medium (400px)" default="true">medium</value>
      <value name="large" display-name-key="Large (600px)">large</value>
      <value name="full" display-name-key="Full Width">full</value>
    </property>

    <property name="contentZones" display-name-key="Content Zones" description-key="JSON array defining dynamic content zones: [{title, body, icon}]." of-type="Multiple" usage="input" required="false" />

    <resources>
      <code path="index.ts" order="1" />
    </resources>

    <feature-usage>
      <uses-feature name="WebAPI" required="false" />
    </feature-usage>
  </control>
</manifest>
