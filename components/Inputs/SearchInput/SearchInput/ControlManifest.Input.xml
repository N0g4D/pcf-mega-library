<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="MegaPCF" constructor="SearchInput" version="1.0.0" display-name-key="SearchInput" description-key="Search input with debounce, clear, and loading indicator" control-type="standard">
    <external-service-usage enabled="false" />

    <property name="value" display-name-key="Value" description-key="Current search text." of-type="SingleLine.Text" usage="bound" required="true" />

    <property name="placeholder" display-name-key="Placeholder" description-key="Placeholder text." of-type="SingleLine.Text" usage="input" required="false" />

    <property name="debounceMs" display-name-key="Debounce (ms)" description-key="Delay before notifying output change." of-type="Whole.None" usage="input" required="false" />

    <property name="size" display-name-key="Size" description-key="Input size." of-type="Enum" usage="input" required="false">
      <value name="small" display-name-key="Small">small</value>
      <value name="medium" display-name-key="Medium" default="true">medium</value>
      <value name="large" display-name-key="Large">large</value>
    </property>

    <property name="disabled" display-name-key="Disabled" description-key="Disable the search input." of-type="TwoOptions" usage="input" required="false" />

    <resources>
      <code path="index.ts" order="1" />
    </resources>

    <feature-usage>
      <uses-feature name="WebAPI" required="false" />
    </feature-usage>
  </control>
</manifest>
