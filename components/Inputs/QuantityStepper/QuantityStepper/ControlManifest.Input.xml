<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="MegaPCF" constructor="QuantityStepper" version="1.0.0" display-name-key="QuantityStepper" description-key="Compact quantity selector with +/- buttons" control-type="standard">
    <external-service-usage enabled="false" />

    <property name="value" display-name-key="Value" description-key="Current quantity." of-type="Whole.None" usage="bound" required="true" />

    <property name="min" display-name-key="Min" description-key="Minimum quantity." of-type="Whole.None" usage="input" required="false" />

    <property name="max" display-name-key="Max" description-key="Maximum quantity." of-type="Whole.None" usage="input" required="false" />

    <property name="step" display-name-key="Step" description-key="Increment/decrement step." of-type="Whole.None" usage="input" required="false" />

    <property name="size" display-name-key="Size" description-key="Stepper size." of-type="Enum" usage="input" required="false">
      <value name="small" display-name-key="Small">small</value>
      <value name="medium" display-name-key="Medium" default="true">medium</value>
      <value name="large" display-name-key="Large">large</value>
    </property>

    <property name="disabled" display-name-key="Disabled" description-key="Disable the stepper." of-type="TwoOptions" usage="input" required="false" />

    <resources>
      <code path="index.ts" order="1" />
    </resources>

    <feature-usage>
      <uses-feature name="WebAPI" required="false" />
    </feature-usage>
  </control>
</manifest>
