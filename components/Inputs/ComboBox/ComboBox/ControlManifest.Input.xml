<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="MegaPCF" constructor="ComboBox" version="1.0.0" display-name-key="ComboBox" description-key="Editable combobox with autocomplete suggestions" control-type="standard">
    <external-service-usage enabled="false" />

    <property name="selectedValue" display-name-key="Selected Value" description-key="Currently selected value." of-type="SingleLine.Text" usage="bound" required="true" />

    <property name="options" display-name-key="Options" description-key="JSON array of options: [{value, label}]." of-type="Multiple" usage="input" required="true" />

    <property name="placeholder" display-name-key="Placeholder" description-key="Placeholder text when no selection." of-type="SingleLine.Text" usage="input" required="false" />

    <property name="freeform" display-name-key="Freeform" description-key="Allow typing values not in the options list." of-type="TwoOptions" usage="input" required="false" />

    <property name="appearance" display-name-key="Appearance" description-key="Visual style." of-type="Enum" usage="input" required="false">
      <value name="outline" display-name-key="Outline" default="true">outline</value>
      <value name="underline" display-name-key="Underline">underline</value>
      <value name="filledDarker" display-name-key="Filled Darker">filledDarker</value>
      <value name="filledLighter" display-name-key="Filled Lighter">filledLighter</value>
    </property>

    <property name="disabled" display-name-key="Disabled" description-key="Disable the combo box." of-type="TwoOptions" usage="input" required="false" />

    <resources>
      <code path="index.ts" order="1" />
    </resources>

    <feature-usage>
      <uses-feature name="WebAPI" required="false" />
    </feature-usage>
  </control>
</manifest>
