<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="MegaPCF" constructor="CheckboxGroup" version="1.0.0" display-name-key="CheckboxGroup" description-key="Grouped checkboxes with select-all functionality" control-type="standard">
    <external-service-usage enabled="false" />

    <property name="selectedValues" display-name-key="Selected Values" description-key="Comma-separated selected values." of-type="SingleLine.Text" usage="bound" required="true" />

    <property name="options" display-name-key="Options" description-key="JSON array of options: [{value, label}]." of-type="Multiple" usage="input" required="true" />

    <property name="layout" display-name-key="Layout" description-key="Arrangement of checkboxes." of-type="Enum" usage="input" required="false">
      <value name="vertical" display-name-key="Vertical" default="true">vertical</value>
      <value name="horizontal" display-name-key="Horizontal">horizontal</value>
    </property>

    <property name="disabled" display-name-key="Disabled" description-key="Disable the checkbox group." of-type="TwoOptions" usage="input" required="false" />

    <resources>
      <code path="index.ts" order="1" />
    </resources>

    <feature-usage>
      <uses-feature name="WebAPI" required="false" />
    </feature-usage>
  </control>
</manifest>
