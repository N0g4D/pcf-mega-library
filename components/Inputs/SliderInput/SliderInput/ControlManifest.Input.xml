<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="MegaPCF" constructor="SliderInput" version="1.0.0" display-name-key="SliderInput" description-key="Range slider with single thumb and labels" control-type="standard">
    <external-service-usage enabled="false" />

    <property name="value" display-name-key="Value" description-key="Current slider value." of-type="Decimal" usage="bound" required="true" />

    <property name="min" display-name-key="Min" description-key="Minimum value." of-type="Decimal" usage="input" required="false" />

    <property name="max" display-name-key="Max" description-key="Maximum value." of-type="Decimal" usage="input" required="false" />

    <property name="step" display-name-key="Step" description-key="Step increment." of-type="Decimal" usage="input" required="false" />

    <property name="size" display-name-key="Size" description-key="Slider size." of-type="Enum" usage="input" required="false">
      <value name="small" display-name-key="Small">small</value>
      <value name="medium" display-name-key="Medium" default="true">medium</value>
    </property>

    <property name="disabled" display-name-key="Disabled" description-key="Disable the slider." of-type="TwoOptions" usage="input" required="false" />

    <resources>
      <code path="index.ts" order="1" />
    </resources>

    <feature-usage>
      <uses-feature name="WebAPI" required="false" />
    </feature-usage>
  </control>
</manifest>
