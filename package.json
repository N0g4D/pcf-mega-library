{
  "name": "@pcf-mega/library",
  "version": "1.0.0",
  "description": "The definitive open-source mega-library of 1,000+ Power Apps Component Framework (PCF) controls. Enterprise-grade, Fluent UI v9, fully typed.",
  "author": "PCF Mega Library Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pcf-mega/library.git"
  },
  "keywords": [
    "pcf",
    "powerapps",
    "power-platform",
    "fluent-ui",
    "dataverse",
    "model-driven",
    "canvas-app",
    "component-framework",
    "dynamics-365"
  ],
  "workspaces": [
    "components/*/*"
  ],
  "scripts": {
    "generate:catalog": "node scripts/generate-catalog.js",
    "generate:scaffold": "node scripts/generate-pcf-scaffold.js",
    "mass:generate": "node scripts/mass-generate.js",
    "build:all": "node scripts/build-all.js",
    "build:component": "node scripts/build-component.js",
    "lint": "eslint components/**/*.ts components/**/*.tsx",
    "clean": "node scripts/clean-all.js",
    "validate:manifests": "node scripts/validate-manifests.js",
    "stats": "node scripts/catalog-stats.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@microsoft/eslint-plugin-power-apps": "^0.2.51",
    "@types/node": "^18.19.86",
    "@types/powerapps-component-framework": "^1.3.16",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.25.1",
    "eslint-plugin-promise": "^7.1.0",
    "globals": "^15.15.0",
    "pcf-scripts": "^1",
    "pcf-start": "^1",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.44.0"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.73.4",
    "@fluentui/react-icons": "^2.0.321",
    "@fluentui/react-charting": "^5.23.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
